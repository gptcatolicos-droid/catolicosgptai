{
  "entities": {
    "user": {
      "title": "User",
      "description": "User account schema including custom metadata, active subscription details and credit usage counter",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier matching the user's ID"
        },
        "email": {
          "type": "string",
          "description": "User email address in lowercase"
        },
        "passwordHash": {
          "type": "string",
          "description": "Hashed password using bcrypt"
        },
        "nombre": {
          "type": "string",
          "description": "Display name of the user"
        },
        "plan": {
          "type": "string",
          "description": "Current plan name (e.g. 'free', 'premium', 'admin')"
        },
        "infografiasUsadas": {
          "type": "integer",
          "description": "Number of infographics generated in the current reset period"
        },
        "periodoReset": {
          "type": "string",
          "description": "Formatted period key pointing to the reset timestamp"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp representing user sign-up date"
        },
        "activo": {
          "type": "boolean",
          "description": "Indicates if the user account is active or suspended"
        },
        "customLogo": {
          "type": "string",
          "description": "Optional URL for custom branding logo"
        },
        "customNombre": {
          "type": "string",
          "description": "Optional custom brand name display"
        }
      },
      "required": ["id", "email", "passwordHash", "nombre", "plan", "activo", "createdAt"]
    },
    "coupon": {
      "title": "Coupon",
      "description": "Discount coupon schema used to activate premium plan durations",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique ID for the coupon record"
        },
        "code": {
          "type": "string",
          "description": "Sovereign uppercase promo code"
        },
        "plan": {
          "type": "string",
          "description": "Plan that this coupon awards (e.g. 'premium', 'unlimited')"
        },
        "durationDays": {
          "type": "integer",
          "description": "Duration in days allocated upon redemption"
        },
        "maxUses": {
          "type": "integer",
          "description": "Maximum number of times the coupon code can be redeemed"
        },
        "uses": {
          "type": "integer",
          "description": "Total count of current redemptions"
        },
        "usedBy": {
          "type": "array",
          "description": "Array of user IDs who have redeemed this coupon"
        },
        "expiry": {
          "type": "string",
          "description": "ISO date-time string marking code expiry"
        },
        "activo": {
          "type": "boolean",
          "description": "Determines if coupon can be actively redeemed"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["id", "code", "plan", "maxUses", "uses", "activo", "createdAt"]
    },
    "infografia": {
      "title": "Infografia",
      "description": "Catholic infographic graphic slide metadata and CDN links",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "tema": { "type": "string" },
        "tipo": { "type": "string" },
        "categoria": { "type": "string" },
        "titulo": { "type": "string" },
        "metaDescription": { "type": "string" },
        "altText": { "type": "string" },
        "imagenes": { "type": "array" },
        "totalSlides": { "type": "integer" },
        "formato": { "type": "string" },
        "userPlan": { "type": "string" },
        "userId": { "type": "string" },
        "fechaCreacion": { "type": "string" },
        "fechaISO": { "type": "string" },
        "publicado": { "type": "boolean" },
        "keywords": { "type": "string" }
      },
      "required": ["id", "slug", "tema", "imagenes", "totalSlides", "fechaCreacion"]
    },
    "video": {
      "title": "Video",
      "description": "Curated YouTube cathodic video training resource",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "titulo": { "type": "string" },
        "canal": { "type": "string" },
        "youtubeId": { "type": "string" },
        "comentario": { "type": "string" },
        "categoria": { "type": "string" },
        "publicado": { "type": "boolean" }
      },
      "required": ["id", "slug", "titulo", "youtubeId"]
    },
    "podcast": {
      "title": "Podcast",
      "description": "Curated audio episode or podcast link with iframe HTML",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "titulo": { "type": "string" },
        "autor": { "type": "string" },
        "descripcion": { "type": "string" },
        "embedUrl": { "type": "string" },
        "embedHtml": { "type": "string" },
        "spotifyUrl": { "type": "string" },
        "categoria": { "type": "string" },
        "publicado": { "type": "boolean" }
      },
      "required": ["id", "slug", "titulo", "spotifyUrl"]
    },
    "post": {
      "title": "Post",
      "description": "SEO-optimized catechetical blog article with markdown body",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "titulo": { "type": "string" },
        "descripcion": { "type": "string" },
        "extracto": { "type": "string" },
        "keywords": { "type": "string" },
        "categoria": { "type": "string" },
        "contenidoMd": { "type": "string" },
        "fechaCreacion": { "type": "string" },
        "imagenPortada": { "type": "string" },
        "publicado": { "type": "boolean" }
      },
      "required": ["slug", "titulo", "contenidoMd", "fechaCreacion"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Sync collection of active registered faithful"
    },
    "/coupons/{couponId}": {
      "schema": "coupon",
      "description": "Sync collection of platform reward and tier upgraders"
    },
    "/infografias/{infografiaId}": {
      "schema": "infografia",
      "description": "Sync collection for durable persistence of custom and generated infographics"
    },
    "/videos/{videoId}": {
      "schema": "video",
      "description": "Sync collection for curated formative videos list"
    },
    "/podcasts/{podcastId}": {
      "schema": "podcast",
      "description": "Sync collection for curated audio and Spotify programs list"
    },
    "/posts/{postId}": {
      "schema": "post",
      "description": "Sync collection for custom, enriched, and default search-engine optimized blog posts"
    }
  }
}
